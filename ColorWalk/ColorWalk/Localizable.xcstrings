    "alert.mission.change.message": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "⚠️ Changing the mission color will clear all captured photos. Continue?"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "⚠️ 미션 색상 변경: 현재 촬영한 사진이 모두 초기화되며 저장되지 않습니다. 계속하시겠습니까?"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "⚠️ 更改任务颜色将清除所有已拍摄的照片。是否继续？"
          }
        },
        "zh-Hant-HK": {
          "stringUnit": {
            "state": "translated",
            "value": "⚠️ 更改任務顏色將清除所有已拍攝的相片。是否繼續？"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "⚠️ 更改任務顏色將清除所有已拍攝的照片。是否繼續？"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "⚠️ ミッションの色を変更すると、撮影した写真がすべて削除されます。続けますか？"
          }
        }
      }
    },
    "alert.mission.change.title": {
      "localizations": {
