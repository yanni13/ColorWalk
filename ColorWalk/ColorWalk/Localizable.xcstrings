    "onboarding.empty.desc": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Capture the beautiful colors around you\nas you take a walk."
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "산책하면서 주변의 아름다운 색을\n카메라로 담아보세요"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "在散步的同时，\n用相机捕捉周围美丽的色彩吧"
          }
        },
        "zh-Hant-HK": {
          "stringUnit": {
            "state": "translated",
            "value": "在散步的同時，\n用相機捕捉周圍美麗的色彩吧"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "在散步的同時，\n用相機捕捉周圍美麗的色彩吧"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "散歩しながら、周りの美しい色を\nカメラで収めてみてください"
          }
        }
      }
    },
    "onboarding.empty.title": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "No colors collected yet"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "아직 수집한 색이 없어요"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "还没有收集到颜色"
          }
        },
        "zh-Hant-HK": {
          "stringUnit": {
            "state": "translated",
            "value": "還沒有收集到顏色"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "還沒有收集到顏色"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "まだ収集した色がありません"
