        }
      }
    },
    "onboarding.subtitle": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Fill every place your gaze lingers,\nwith colors uniquely yours."
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "당신의 시선이 머문 자리를,\n당신만의 색으로 가득 채워보세요"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "将您目光所停留的地方，\n用只属于您的颜色填满吧"
          }
        },
        "zh-Hant-HK": {
          "stringUnit": {
            "state": "translated",
            "value": "將您目光所停留的地方，\n用只屬於您的顏色填滿吧"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "將您目光所停留的地方，\n用只屬於您的顏色填滿吧"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "あなたの視線が止まる場所を、\nあなただけの色で満たしてみてください"
          }
        }
      }
    },
